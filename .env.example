# Backend GraphQL API URL (client-side, baked at build time)
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8080/graphql

# Backend GraphQL URL (server-side, used by API proxy and NextAuth at runtime)
GRAPHQL_BACKEND_URL=http://localhost:8080/graphql

# NextAuth Configuration
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Note: Copy this file to .env.local and update the values
# For Docker deployment, set GRAPHQL_BACKEND_URL=http://backend:8080/graphql
